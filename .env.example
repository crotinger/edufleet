# Docker Compose environment for edufleet
# Copy to .env and fill in secrets. Do NOT commit .env.

# Host ports exposed by the app container
APP_HTTP_PORT=8080
APP_HTTPS_PORT=8443

# Host-visible Postgres port (bound to 127.0.0.1 only)
POSTGRES_PORT=5432

# Caddy SERVER_NAME — use ":80" for plain HTTP on LAN, or a hostname like
# "edufleet.lan" to let Caddy manage TLS (internal CA) automatically.
SERVER_NAME=:80

# Postgres
POSTGRES_DB=edufleet
POSTGRES_USER=edufleet
POSTGRES_PASSWORD=changeme
