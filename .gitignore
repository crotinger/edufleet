# =============================================================================
# edufleet — .gitignore
# Layout: compose + docker/ at root, Laravel app under src/.
# Laravel's per-directory stub .gitignore files (under src/storage/**/ and
# src/bootstrap/cache/) stay in place and handle content-ignoring for those
# directories — we don't need to duplicate those rules here.
# =============================================================================

# -------- Secrets (NEVER commit) --------
/.env
/.env.*
!/.env.example
/src/.env
/src/.env.*
!/src/.env.example
/src/auth.json

# -------- Dependencies (regenerated from composer.lock / package-lock.json) --
/src/vendor/
/src/node_modules/

# -------- Frontend build artifacts (regenerated by `npm run build`) ---------
/src/public/build/
/src/public/hot
/src/public/storage
/src/public/mix-manifest.json

# -------- Filament published assets (regenerated by `artisan filament:assets`)
# Comment these out if you prefer to commit published vendor assets.
/src/public/js/filament/
/src/public/css/filament/
/src/public/fonts/filament/

# -------- Laravel runtime / caches ------------------------------------------
/src/.phpunit.cache/
/src/.phpunit.result.cache
/src/storage/*.key
/src/storage/pail
/src/storage/app/public
/src/storage/debugbar/
# storage/framework/{cache,sessions,views,testing} already have their own
# per-directory .gitignore shipped by Laravel — leave them alone.
# bootstrap/cache/ same.

# -------- Dev tooling logs ---------------------------------------------------
/src/npm-debug.log
/src/yarn-error.log
/src/yarn-debug.log
/src/npm-debug.log.*
/src/yarn-error.log.*

# -------- Testing / CI scratch -----------------------------------------------
/src/.phpactor.json
/src/.phpunit.result.cache
/coverage/
/.phpunit.cache/

# -------- Editors / IDEs -----------------------------------------------------
/.idea/
/.vscode/
/.fleet/
/.nova/
/.zed/
/.cursor/
/.phpstorm.meta.php
*.swp
*.swo
*~
.project
.settings/
.buildpath

# -------- OS cruft -----------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# -------- Docker local state (we use named volumes, but just in case) --------
/docker-compose.override.yml
/docker-compose.override.yaml

# -------- Claude Code / AI assistant scratch ---------------------------------
/.claude/
/.cursor-rules
/tmp/
/scratch/

# -------- Ad-hoc / local-only --------------------------------------------------
/*.local
/local/

# Local-only seeders — populate with test data specific to the operator's
# environment (real district addresses, etc.) that should never be committed.
# Name them *LocalSeeder.php or *LocalTestSeeder.php; run via:
#   php artisan db:seed --class=FooLocalSeeder
/src/database/seeders/*LocalSeeder.php
/src/database/seeders/*LocalTestSeeder.php
